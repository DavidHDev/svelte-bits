{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "chroma-grid",
  "type": "registry:component",
  "title": "Chroma Grid",
  "description": "Card grid with cursor-following spotlight reveal of color from a desaturated overlay (GSAP).",
  "categories": [
    "components"
