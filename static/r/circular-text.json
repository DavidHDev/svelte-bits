{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "circular-text",
  "type": "registry:component",
  "title": "Circular Text",
  "description": "Layouts characters around a circle with optional rotation animation.",
  "categories": [
    "text-animations"
  ],
  "files": [
    {
      "path": "CircularText.svelte",
      "content": "<script lang=\"ts\">\n\tinterface VelocityMapping {\n\t\tinput: [number, number];\n\t\toutput: [number, number];\n\t}\n\n\ttype Props = {\n\t\ttexts?: string[];\n\t\tvelocity?: number;\n\t\tclassName?: string;\n\t\tdamping?: number;\n\t\tstiffness?: number;\n\t\tnumCopies?: number;\n\t\tvelocityMapping?: VelocityMapping;\n\t\tparallaxClassName?: string;\n\t\tscrollerClassName?: string;\n\t};\n\n\tlet {\n\t\ttexts = [],\n\t\tvelocity = 100,\n\t\tclassName = '',\n\t\tdamping = 50,\n\t\tstiffness = 400,\n\t\tnumCopies = 6,\n\t\tvelocityMapping = { input: [0, 1000], output: [0, 5] },\n\t\tparallaxClassName = '',\n\t\tscrollerClassName = ''\n\t}: Props = $props();\n\n\tconst copies = $derived(Array.from({ length: numCopies }, (_, i) => i));\n\tconst copySpans = $derived(texts.map(() => [] as HTMLSpanElement[]));\n\tconst scrollerEls = $derived(texts.map(() => undefined as HTMLDivElement | undefined));\n\n\tfunction wrap(min: number, max: number, v: number): number {\n\t\tconst range = max - min;\n\t\tconst mod = (((v - min) % range) + range) % range;\n\t\treturn mod + min;\n\t}\n\n\tfunction lerp(a: number, b: number, t: number): number {\n\t\treturn a + (b - a) * t;\n\t}\n\n\tfunction mapRange(value: number, inMin: number, inMax: number, outMin: number, outMax: number): number {\n\t\treturn ((value - inMin) / (inMax - inMin)) * (outMax - outMin) + outMin;\n\t}\n\n\t$effect(() => {\n\t\tconst _texts = texts.slice();\n\n\t\tlet baseXArr = _texts.map(() => 0);\n\t\tlet directionFactors = _texts.map((_, i) => (i % 2 !== 0 ? -1 : 1));\n\t\tlet lastScrollY = window.scrollY;\n\t\tlet scrollVelocity = 0;\n\t\tlet smoothVelocity = 0;\n\n\t\tconst handleScroll = () => {\n\t\t\tconst current = window.scrollY;\n\t\t\tscrollVelocity = current - lastScrollY;\n\t\t\tlastScrollY = current;\n\t\t};\n\t\twindow.addEventListener('scroll', handleScroll, { passive: true });\n\n\t\tlet lastTime: number | null = null;\n\t\tlet rafId: number;\n\n\t\tconst loop = (time: number) => {\n\t\t\tif (lastTime === null) {\n\t\t\t\tlastTime = time;\n\t\t\t\trafId = requestAnimationFrame(loop);\n\t\t\t\treturn;\n\t\t\t}\n\n\t\t\tconst delta = time - lastTime;\n\t\t\tlastTime = time;\n\n\t\t\tconst springFactor = Math.min(1, (stiffness / damping) * (delta / 1000));\n\t\t\tsmoothVelocity = lerp(smoothVelocity, scrollVelocity, springFactor);\n\t\t\tscrollVelocity = lerp(scrollVelocity, 0, 0.1);\n\n\t\t\tconst velocityFactor = mapRange(\n\t\t\t\tsmoothVelocity,\n\t\t\t\tvelocityMapping.input[0],\n\t\t\t\tvelocityMapping.input[1],\n\t\t\t\tvelocityMapping.output[0],\n\t\t\t\tvelocityMapping.output[1]\n\t\t\t);\n\n\t\t\t_texts.forEach((_, i) => {\n\t\t\t\tconst baseVelocity = i % 2 !== 0 ? -velocity : velocity;\n\n\t\t\t\tif (velocityFactor < 0) directionFactors[i] = -1;\n\t\t\t\telse if (velocityFactor > 0) directionFactors[i] = 1;\n\n\t\t\t\tlet moveBy = directionFactors[i] * baseVelocity * (delta / 1000);\n\t\t\t\tmoveBy += directionFactors[i] * moveBy * velocityFactor;\n\t\t\t\tbaseXArr[i] += moveBy;\n\n\t\t\t\tconst copyWidth = copySpans[i]?.[0]?.offsetWidth ?? 0;\n\t\t\t\tconst x = copyWidth > 0 ? wrap(-copyWidth, 0, baseXArr[i]) : 0;\n\n\t\t\t\tif (scrollerEls[i]) {\n\t\t\t\t\tscrollerEls[i]!.style.transform = `translateX(${x}px)`;\n\t\t\t\t}\n\t\t\t});\n\n\t\t\trafId = requestAnimationFrame(loop);\n\t\t};\n\n\t\trafId = requestAnimationFrame(loop);\n\n\t\treturn () => {\n\t\t\tcancelAnimationFrame(rafId);\n\t\t\twindow.removeEventListener('scroll', handleScroll);\n\t\t};\n\t});\n</script>\n\n<section>\n\t{#each texts as text, i (i)}\n\t\t<div class=\"relative overflow-hidden {parallaxClassName}\">\n\t\t\t<div\n\t\t\t\tbind:this={scrollerEls[i]}\n\t\t\t\tclass=\"flex whitespace-nowrap text-center font-sans text-4xl font-bold tracking-[-0.02em] drop-shadow md:text-[5rem] md:leading-20 {scrollerClassName}\"\n\t\t\t>\n\t\t\t\t{#each copies as j (j)}\n\t\t\t\t\t<span\n\t\t\t\t\t\tbind:this={copySpans[i][j]}\n\t\t\t\t\t\tclass=\"shrink-0 {className}\"\n\t\t\t\t\t>\n\t\t\t\t\t\t{text}&nbsp;\n\t\t\t\t\t</span>\n\t\t\t\t{/each}\n\t\t\t</div>\n\t\t</div>\n\t{/each}\n</section>",
      "type": "registry:component",
      "target": "$lib/components/svelte-bits/CircularText.svelte"
    }
  ],
  "dependencies": [
    "motion"
  ]
}
